\cs_new:Npn \__codeverb_range:wTF #1 \q_nil - \q_stop
  {
    \tl_set:Nn \l__codeverb_tmp_xerr_tl {#1}
    \tl_if_blank:nTF {#1}
  }

\cs_new:Npn \__codeverb_range:wNN #1 - #2 - #3 \q_stop #4 #5
  {
    \quark_if_nil:nTF {#2}
      { % just #1
        \tl_if_blank:nTF {#1}
          {  %% default when 'nothing is given'
                \tl_set:Nn #4 {1}
                \tl_set:Nn #5 {1}
          }
          {
            \regex_if_match:NnTF \c__codeverb_notint_regex {#1}
              { %%% err
              \msg_error:nnnn { codeverbatim / syntax } { nan range } 
                {nan:01} {'#1' ~-~ '#2'}
                \tl_set:Nn #4 {1}
                \tl_set:Nn #5 {1}
              }
              {
                \tl_set:Nn #4 {#1}
                \tl_set_eq:NN #5 #4
              }
          }
      }
      { % hopefuly #1 and #2
        \__codeverb_range:wTF #3 \q_stop
          { %% everything ok, so far (no left over)
            \regex_if_match:NnTF \c__codeverb_notint_regex {#1}
              { %%err
                  \msg_error:nnnn { codeverbatim / syntax } { nan range } 
                    {nan:03} {'#1' ~-~ '#2'}
                    \tl_set:Nn #4 {1}
                    \tl_set:Nn #5 {1}
              }
              {
                \regex_if_match:NnTF \c__codeverb_notint_regex {#2}
                  { %%err
                  \msg_error:nnnn { codeverbatim / syntax } { nan range } 
                    {nan:02} {'#1' ~-~ '#2'}
                  
                    \tl_set:Nn #4 {#1}
                    \tl_set_eq:NN #5 #4
                  }
                  {
                    \tl_set:Nn #4 {#1}
                    \tl_set:Nn #5 {#2}
                  }
              }          
          }
          { %% err, 
            \msg_error:nnne { codeverbatim / syntax } { nan range } 
              {nan:04} {'\exp_not:n{#1}' ~-~ '\exp_not:n{#2}'~ '\exp_not:V \l__codeverb_tmp_xerr_tl '} 
                    \tl_set:Nn #4 {1}
                    \tl_set:Nn #5 {1}

          }
      }
  } 



\int_new:N \l__codeverb_tmpa_int
\int_new:N \l__codeverb_tmpb_int


\regex_const:Nn \c__codeverb_notint_regex {[^0-9]+?}
  
\cs_new_protected:Npn \__codeverb_range_merge:Nnnn #1#2#3#4
  {
    \seq_if_exist:cTF { #2 _ #3 _seq}
      {
        \str_compare:nNnTF {#4} = {end}
          {
            \__codeverb_merge:Ne #1 
              { \seq_item:cn { #2 _ #3 _seq}{ \int_use:c { #2 _ #3 _int} } }
          }
          {
            \__codeverb_range:wNN #4 - \q_nil - \q_stop \l__codeverb_tmpa_tl \l__codeverb_tmpb_tl
    
            \str_compare:nNnTF \l__codeverb_tmpb_tl = {end}
              {
                \int_set:Nn \l__codeverb_tmpb_int { \int_use:c { #2 _ #3 _int} }
              }           
              {
                \int_compare:nNnTF {\l__codeverb_tmpb_tl} > { \int_use:c { #2 _ #3 _int} }
                  {
                    \int_set:Nn \l__codeverb_tmpb_int { \int_use:c { #2 _ #3 _int} }
                    \msg_error:nnne { codeverbatim / syntax } { nan range } 
                      {val:01} {' \exp_not:V \l__codeverb_tmpa_tl ' ~-~ ' \exp_not:V \l__codeverb_tmpb_tl '}
                  }
                  {
                    \int_compare:nNnTF {\l__codeverb_tmpb_tl} < 1
                      {
                        \int_set:Nn \l__codeverb_tmpb_int {1}
                        \msg_error:nnne { codeverbatim / syntax } { nan range } 
                          {val:02} {' \exp_not:V \l__codeverb_tmpa_tl ' ~-~ ' \exp_not:V \l__codeverb_tmpb_tl '}
                      }
                      {
                        \int_set:Nn \l__codeverb_tmpb_int { \l__codeverb_tmpb_tl }
                      }
                  }
              }

            \str_compare:nNnTF \l__codeverb_tmpa_tl = {end}
              {
                \int_set:Nn \l__codeverb_tmpa_int { \int_use:c { #2 _ #3 _int} }
              }           
              {
                \int_compare:nNnTF {\l__codeverb_tmpa_tl} < 1
                  {
                    \int_set:Nn \l__codeverb_tmpa_int {1}
                    \msg_error:nnne { codeverbatim / syntax } { nan range } 
                      {val:03} {' \exp_not:V \l__codeverb_tmpa_tl ' ~-~ ' \exp_not:V \l__codeverb_tmpb_tl '}
                  }
                  {
                    \int_set:Nn \l__codeverb_tmpa_int { \l__codeverb_tmpa_tl }
                  }
              }
            \int_compare:nNnTF \l__codeverb_tmpa_int > \l__codeverb_tmpb_int
              {
                \int_set_eq:NN \l__codeverb_tmpa_int \l__codeverb_tmpb_int
                \msg_error:nnne { codeverbatim / syntax } { nan range } 
                  {val:04} {' \exp_not:V \l__codeverb_tmpa_tl ' ~-~ ' \exp_not:V \l__codeverb_tmpb_tl '}
              }
              {}

            \int_step_inline:nnn \l__codeverb_tmpa_int \l__codeverb_tmpb_int
              {
                \__codeverb_merge:Ne #1 
                  { \seq_item:cn { #2 _ #3 _seq}{##1} }
              }
         }
     }
     {
      \msg_error:nnnn { codeverbatim / syntax } {seq undef}
        {syntax:02} {#3}
     }
  }
\cs_generate_variant:Nn \__codeverb_range_merge:Nnnn {Nnee , NnnV , NnVV}  


\cs_new:Npn \__codeverb_opt:wNN #1 [ #2 ] #3 \q_stop #4 #5
  {
    \quark_if_nil:nTF {#2}
      { % just #1
        \tl_set:Nn #4 {#1}
        \tl_set:Nn #5 {end}
      }
