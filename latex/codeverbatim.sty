\msg_new:nnnn { codeverbatim / syntax } {seq undef}
  {
    (#1)~There ~is ~ no ~stored ~sequence~'#2'
  }
  {
    You~tried~to~use~a~non~defined~store~sequence:~'#2'.
    ~Error~Code~ ID:<#1>.
  }

\msg_new:nnnn { codeverbatim / syntax } {invalid range}
  {
    (#1)~The ~range~ '#2' ~is ~ invalid. ~Using~ '1'~ instead
  }
  {
    There ~is ~a ~syntax ~error~ in ~the~range~ specification.
    ~Error~Code~ ID:<#1>.
  }

\msg_new:nnnn { codeverbatim / syntax } { nan range }
  {
    (#1)~ Invalid~ number/range:~ #2
  }
  {
    There ~is ~a ~syntax ~error~ in ~the~range~ specification.
    ~Error~Code~ ID:<#1>.
  }


