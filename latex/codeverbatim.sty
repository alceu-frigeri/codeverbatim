\cs_new_protected:Npn \__codeverb_set_store_cmds:nn #1#2
  {
    \cs_new_protected:cpn  {#2_store_set_seq:n} ##1
      {
        \seq_if_exist:cF {#1 #2 _ ##1 _seq}
          {
            \seq_new:c {#1 #2 _ ##1 _seq}
            \int_new:c {#1 #2 _ ##1 _int}
            \cs_new:cpe { #2 _ ##1 _gput_right:n} ####1
              {
                \exp_not:N \int_gincr:N \exp_not:c {#1 #2 _ ##1 _int}
                \exp_not:N \seq_gput_right:Nn \exp_not:c {#1 #2 _ ##1 _seq} {####1}
              }      
          }        
        \cs_set_eq:Nc \codeverb_store_gput_right:n { #2 _ ##1  _gput_right:n}
      }

    \cs_new_protected:cpn {#2_merge:Nnn}  ##1##2##3
      {
        \bool_set_true:N \l__codeverb_first_merge_bool
        \tl_if_blank:nTF {##3}
          {
            \clist_map_inline:nn {##2}
              { 
                \__codeverb_opt_a:wNN ####1 [ \q_nil \q_stop \l__codeverb_tmpa_tl \l__codeverb_tmpb_tl  %]
                \__codeverb_range_merge:NnVV   ##1 {#1 #2} \l__codeverb_tmpa_tl \l__codeverb_tmpb_tl
              }
          }
          {
            \clist_map_inline:nn {##2}
              { 
                \clist_map_inline:nn {##3}
                  {
                    \tl_set:Nn \l__codeverb_tmpa_tl {########1}
                    \tl_remove_all:Nn \l__codeverb_tmpa_tl {~}
                    \__codeverb_range_merge:NnnV ##1 {#1 #2} {####1} \l__codeverb_tmpa_tl
                  }
              }
          }
      }  
  }

