\cs_new:Npn\__codeverb_env_begin:
  {
    \bool_set_true:N \l__codeverb_first_entry_bool
    \cs_set_eq:NN \__codeverb_body_build:n \__codeverb_body_build_begin:n
    \tl_gclear:N \g__codeverb_tmp_build_tl
    \group_begin:
      \__codeverb_set_others:  
      \char_set_catcode_other:n {`\^^M}
      \__codeverb_linescan:w
  }


\group_begin:
  \char_set_catcode_other:n {`\^^M} \endlinechar=-1 
  \char_set_catcode_other:n {`\^^J}

  \cs_new:Npn \__codeverb_body_build:n #1 {}
  \cs_generate_variant:Nn \__codeverb_body_build:n {o,e}  

  \cs_new:Npn \__codeverb_body_build_begin:n #1
    {
      \bool_if:NTF \l__codeverb_first_entry_bool
        {
          \tl_gput_right:Nn \g__codeverb_tmp_build_tl {^^J}
          \bool_set_false:N \l__codeverb_first_entry_bool
          \bool_if:NTF \l__codeverb_drop_first_bool
            { }
            {
              \tl_if_blank:nTF {#1}
                { }
                {
                  \cs_set_eq:NN \__codeverb_body_build:n \__codeverb_body_build_rest:n 
                  \tl_gput_right:Nn \g__codeverb_tmp_build_tl {#1 ^^J}
                }
            }
        }
        {
          \bool_if:NTF \l__codeverb_drop_blanks_bool
            {
              \tl_if_blank:nTF {#1}
                { }
                {
                  \cs_set_eq:NN \__codeverb_body_build:n \__codeverb_body_build_rest:n 
                  \tl_gput_right:Nn \g__codeverb_tmp_build_tl {#1 ^^J}
                }
            }
            {
              \cs_set_eq:NN \__codeverb_body_build:n \__codeverb_body_build_rest:n 
              \tl_gput_right:Nn \g__codeverb_tmp_build_tl {#1 ^^J}
            }
        }    
    }
  \cs_new:Npn \__codeverb_body_build_rest:n #1
    {
      \tl_gput_right:Nn \g__codeverb_tmp_build_tl {#1 ^^J}
    }


  \cs_new:Npn \__codeverb_set_env_linescan:NNNn #1#2#3#4
    {        
      \cs_new:cpn {__codeverb_#4_linescan:w} ##1 ^^M
        {
          \regex_split:NnNTF  #1 {##1} \l__codeverb_tmpa_seq
            {
              \int_gincr:N #3
            }
            {}
          \regex_split:NnNTF  #2 {##1} \l__codeverb_lastline_seq
            {
              \int_if_zero:nTF {#3}
                {
                  \seq_pop_left:NN \l__codeverb_lastline_seq \l__codeverb_left_tl
                  \seq_pop_left:NN \l__codeverb_lastline_seq \l__codeverb_left_tl
                  \seq_pop_right:NN \l__codeverb_lastline_seq \l__codeverb_right_tl
                  \seq_pop_right:NN \l__codeverb_lastline_seq \l__codeverb_right_tl
                  \tl_gset_eq:NN \g__codeverb_tmpa_tl \l__codeverb_right_tl
                  \tl_if_blank:VTF \l__codeverb_left_tl
                    {}
                    {
                      \__codeverb_body_build:o \l__codeverb_left_tl
                    }
                  \cs_set:Npn \__codeverb_linescan:w
                    {
                      \group_end: \end{#4} 
                      \tl_retokenize:V \g__codeverb_tmpa_tl
                    }
                }
                {
                  \int_gdecr:N #3
                  \__codeverb_body_build:n {##1}
                }
            }
            {
              \__codeverb_body_build:n {##1}
            }
          \__codeverb_linescan:w
        } 
    }
    
\group_end:
