  {

    \l__codeverb_opt_defaults_tl
    \keys_set:nn { codeverb / new env } {#1}
    
    \bool_if:NTF \l__codeverb_opt_ig_first_bool
      { \tl_set:Nn \l__codeverb_tmpa_tl { \codeverb_set_drop_first_true: } }
      { \tl_set:Nn \l__codeverb_tmpa_tl { \codeverb_set_drop_first_false: } }
    \bool_if:NTF \l__codeverb_opt_ig_blank_bool
      { \tl_put_right:Nn \l__codeverb_tmpa_tl  { \codeverb_set_drop_blanks_true: } }
      { \tl_put_right:Nn \l__codeverb_tmpa_tl  { \codeverb_set_drop_blanks_false: } }
    
    \bool_if:NTF \l__codeverb_opt_seq_bool
      {
        \bool_if:NTF \l__codeverb_opt_seq_public_bool
          {
            \__codeverb_set_store_cmds:nn {g__}{#2_#3}
            \tl_put_right:Ne \l__codeverb_tmpa_tl 
              {
                \exp_not:N \cs_set_eq:NN 
                  \exp_not:N \codeverb_store_set_seq:n 
                  \exp_not:c { #2_#3 _store_set_seq:n }
              }
          }
          {
            \__codeverb_set_store_cmds:nn {g}{__ #2_#3}
            \tl_put_right:Ne \l__codeverb_tmpa_tl 
              {
                \exp_not:N \cs_set_eq:NN 
                  \exp_not:N \codeverb_store_set_seq:n 
                  \exp_not:c { __ #2_#3 _store_set_seq:n }
              }
          }
      }
      {
      }

    \exp_args:NVV
    \__codeverb_new_environment:NNcVnnnn
      \l__codeverb_opt_verb_tl \l__codeverb_opt_lineproc_tl
      {__codeverb_#3_linescan:w}
      \l__codeverb_tmpa_tl
      {#3}
  }

