\cs_new_protected:Npn \__codehl_lang_dlim_new:nnnn #1#2#3#4
  {
%  \tl_show:n {<<dlim_new>>{#1}{#2}{#3}{#4}}
    \tl_if_blank:nTF {#2}
      { % nothing giving... => msg_error
      }
      {
        \tl_if_blank:nTF {#3}
          { % nothing giving... => msg_error
          }
          {
            \__codehl_get_dlimit:NNNw 
              \l__codehl_tmpa_tl \l__codehl_tmpb_tl
              #2 \q_stop
            \__codehl_get_dlimit:NNNw 
              \l__codehl_tmpc_tl \l__codehl_tmpd_tl
              #3 \q_stop

            \prop_if_in:cVTF { g__codehl_lang_dlimit_ #1 _A_prop }
              \l__codehl_tmpa_tl
              {
                \prop_get:cVN { g__codehl_lang_dlimit_ #1 _A_prop }
                  \l__codehl_tmpa_tl
                  \l__codehl_tmpe_tl
                \exp_args:No
                \seq_put_right:Ne \l__codehl_tmpe_tl
                  {
                    { \exp_not:V \l__codehl_tmpa_tl }
                    { \exp_not:V \l__codehl_tmpb_tl }
                    { \exp_not:V \l__codehl_tmpc_tl }
                    { \exp_not:V \l__codehl_tmpd_tl }
                    { \exp_not:n {#4} }
                  }
              }
              {
                \int_incr:c { g__codehl_lang_dlimit_count_ #1 _int }
                \seq_new:c {  g__codehl_lang_dlimit_count_ #1 _ \int_use:c { g__codehl_lang_dlimit_count_ #1 _int } _seq }
                \prop_put:cVe { g__codehl_lang_dlimit_ #1 _A_prop } 
                  \l__codehl_tmpa_tl { \exp_not:c {  g__codehl_lang_dlimit_count_ #1 _ \int_use:c { g__codehl_lang_dlimit_count_ #1 _int } _seq } }
                \seq_put_right:ce { g__codehl_lang_dlimit_count_ #1 _ \int_use:c { g__codehl_lang_dlimit_count_ #1 _int } _seq }
                  {
                    { \exp_not:V \l__codehl_tmpa_tl }
                    { \exp_not:V \l__codehl_tmpb_tl }
                    { \exp_not:V \l__codehl_tmpc_tl }
                    { \exp_not:V \l__codehl_tmpd_tl }
                    { \exp_not:n {#4} }
                  }
              }            
          }         
      } 
  }

