\group_begin:
  \char_set_catcode_other:n {`\^^J}

  \cs_new:Npn \__codehl_line_proc:w #1 ^^J
    {
      \quark_if_nil:NTF {#1} {
          \cs_set_eq:NN \__codehl_line_next:w \prg_do_nothing:
      } {
        \tl_clear:N \l__codehl_build_line_tl
        \tl_clear:N \l__codehl_build_keywd_tl
        \tl_clear:N \l__codehl_build_cs_tl      
        \cs_set_eq:NN \__codehl_tok_proc:N  \__codehl_tok_start:N
        
        \__codehl_tok_proc:N #1 \q_nil %%%
      }
      
      \l__codehl_build_line_tl \par
      \tl_clear:N \l__codehl_build_line_tl
      \__codehl_line_next:w
    }
    
