%%%%%%%
%%%
%%% Just an attempt at having my package's info in a regular way
%%%   \pkginfograb_set:nn {<pkg-name>} { props} sets package info
%%%
%%%   \pkginfograbProvidesExplPackage {<pkg-name>} { props} sets package info
%%%     and calls \ProvidesExplPackage
%%%
%%%%%%%
\RequirePackage{pkginfograb}
\pkginfograbProvidesExplPackage {codehighlight}
  {
     name        = {codehighlight} ,
     prefix      = {codehl} ,
     date        = {2026/04/27} ,
     version     = {0.1} ,
     description = {Code highlighting for codelisting/codeverbatim}
  }
%%%%%%%
%%% End of cut-n-paste
%%%%%%%

%\input{code-ext}

\tl_new:N \l__codehl_build_line_tl
\tl_new:N \l__codehl_build_keywd_tl
\tl_new:N \l__codehl_build_cs_tl
\tl_new:N \l__codehl_build_comment_tl %% to grab 'comments chars' while finding out 'which case?'

%% pois, pois (pt Portugal)
%\prg_set_eq_conditional:NNn \token_if_eq_charcode:nN \token_if_eq_charcode:NN {TF}
%\prg_generate_conditional_variant:Nnn \token_if_eq_charcode:nN {o} {TF}




%%%%%%%%%%%%%%%
%%%
%%% Note: since the many if ladder are unavoidable
%%% using a more compact 'c like' formatting
%%%
%%%%%%%%%%%%%%%

\group_begin:
  \char_set_catcode_other:n {`\^^J}

  \cs_new:Npn \__codehl_line_proc:w #1 ^^J
    {
      \quark_if_nil:NTF {#1} {
          \cs_set_eq:NN \__codehl_line_next:w \prg_do_nothing:
      } {
        \tl_clear:N \l__codehl_build_line_tl
        \tl_clear:N \l__codehl_build_keywd_tl
        \tl_clear:N \l__codehl_build_cs_tl      
        \cs_set_eq:NN \__codehl_tok_proc:N  \__codehl_tok_start:N
        
        \__codehl_tok_proc:N #1 \q_nil %%%
      }
      
      \l__codehl_build_line_tl \par
      \tl_clear:N \l__codehl_build_line_tl
      \__codehl_line_next:w
    }
    
    
\group_end:

\tl_const:Ne \c__codehl_tex_bslash_tl     { \char_generate:nn {92}{12} }
\tl_const:Ne \c__codehl_tex_slash_tl      { \char_generate:nn {47}{12} }
\tl_const:Ne \c__codehl_tex_comment_a_tl  { \char_generate:nn {37}{12} } %% that's a %
\tl_const:Ne \c__codehl_tex_comment_aa_tl { \char_generate:nn {36}{12} } %% that's a $


%%%%%%%%%%%%%%%%%%%%%
%%%
%%% Using low level if's since it will process whatever code, a token (byte) at a time.
%%%
%%%%%%%%%%%%%%%%%%%%%



%%%%%%%
%%% 'main' tok format
%%%%%%%
\cs_new:Npn \__codehl_fmt_tok:nn #1#2
  { \tl_put_right:Nn \l__codehl_build_line_tl { { #1 #2 } } }
\cs_generate_variant:Nn \__codehl_fmt_tok:nn {o , V}  

%%%%%%%
%%% 'specialized' format ones
%%%%%%%
\cs_new:Npn \__codehl_fmt_cs:Nn #1#2
  {
    \tl_if_exist:NTF #1
      { \__codehl_fmt_tok:Vn #1 {\c__codehl_tex_bslash_tl #2}  }
      { \tl_put_right:Nn \l__codehl_build_line_tl {\c__codehl_tex_bslash_tl #2} }    
  }
\cs_generate_variant:Nn \__codehl_fmt_cs:Nn {co}

\cs_new:Npn \__codehl_fmt_keywd:Nn #1#2
  {
    \tl_if_exist:NTF #1
      { \__codehl_fmt_tok:Vn #1 {#2}  }
      { \tl_put_right:Nn \l__codehl_build_line_tl {#2} }    
  }
\cs_generate_variant:Nn \__codehl_fmt_keywd:Nn {co}

\cs_new:Npn \__codehl_fmt_comment:Nnn #1#2#3
  {
    \cs_if_exist:NTF #1
      { \__codehl_fmt_tok:Vn #1 { #2 #3 }  }
      { \tl_put_right:Nn \l__codehl_build_line_tl { #2 #3 } }    
  }
\cs_generate_variant:Nn \__codehl_fmt_comment:Nnn {c , co , cV, No}



\cs_new:Npn \__codehl_tok_tex_comment:w #1 \q_nil
  {
    \__codehl_fmt_comment:con {g__codehl_def_comment_ \g__codehl_activ_set_tl  _tl} \l__codehl_build_comment_tl {#1}
  }

\cs_new:Npn \__codehl_tok_tex_activ_comment:w #1 \q_nil
  {
    \__codehl_fmt_comment:cnn {g__codehl_def_comment_ \g__codehl_activ_set_tl  _tl} {} {\tl_retokenize:n{#1}}
  }


\cs_new:Npn \__codehl_tok_C_comment:w #1 \q_nil
  {
    \__codehl_fmt_comment:con {g__codehl_def_comment_ \g__codehl_activ_set_tl  _tl} \l__codehl_build_comment_tl {#1}
  }



\seq_new:N \g__codehl_lang_seq
\cs_new_protected:Npn \__codehl_lang_new:n #1
  {
    \seq_gput_right:Nn \g__codehl_lang_seq {#1}
    \int_new:c { g__codehl_lang_dlimit_count_ #1 _int }
    \prop_new_linked:c { g__codehl_lang_dlimit_ #1 _A_prop }
    \prop_new_linked:c { g__codehl_lang_dlimit_ #1 _B_prop }
    \tl_new:c {g__codehl_lang_tests_#1_tl}
    \tl_new:c {g__codehl_lang_tests_init_#1_tl}
    
  }


\tl_new:N \l__codehl_tmpa_tl
\tl_new:N \l__codehl_tmpb_tl
\tl_new:N \l__codehl_tmpc_tl
\tl_new:N \l__codehl_tmpd_tl
\tl_new:N \l__codehl_tmpe_tl

\cs_new:Npn \__codehl_get_dlimit:NNNw #1#2#3#4 \q_stop
  {
%    \tl_show:n {<<get_limit>>{#1}{#2}{#3}{#4}}
    
    \tl_set:Nn #1 {#3}
    \tl_if_blank:nTF {#4}
      { \tl_clear:N #2 }
      { \tl_set:Nn #2 {#4} }
  }

\cs_new_protected:Npn \__codehl_lang_dlim_new:nnnn #1#2#3#4
  {
%  \tl_show:n {<<dlim_new>>{#1}{#2}{#3}{#4}}
    \tl_if_blank:nTF {#2}
      { % nothing giving... => msg_error
      }
      {
        \tl_if_blank:nTF {#3}
          { % nothing giving... => msg_error
          }
          {
            \__codehl_get_dlimit:NNNw 
              \l__codehl_tmpa_tl \l__codehl_tmpb_tl
              #2 \q_stop
            \__codehl_get_dlimit:NNNw 
              \l__codehl_tmpc_tl \l__codehl_tmpd_tl
              #3 \q_stop

            \prop_if_in:cVTF { g__codehl_lang_dlimit_ #1 _A_prop }
              \l__codehl_tmpa_tl
              {
                \prop_get:cVN { g__codehl_lang_dlimit_ #1 _A_prop }
                  \l__codehl_tmpa_tl
                  \l__codehl_tmpe_tl
                \exp_args:No
                \seq_put_right:Ne \l__codehl_tmpe_tl
                  {
                    { \exp_not:V \l__codehl_tmpa_tl }
                    { \exp_not:V \l__codehl_tmpb_tl }
                    { \exp_not:V \l__codehl_tmpc_tl }
                    { \exp_not:V \l__codehl_tmpd_tl }
                    { \exp_not:n {#4} }
                  }
              }
              {
                \int_incr:c { g__codehl_lang_dlimit_count_ #1 _int }
                \seq_new:c {  g__codehl_lang_dlimit_count_ #1 _ \int_use:c { g__codehl_lang_dlimit_count_ #1 _int } _seq }
                \prop_put:cVe { g__codehl_lang_dlimit_ #1 _A_prop } 
                  \l__codehl_tmpa_tl { \exp_not:c {  g__codehl_lang_dlimit_count_ #1 _ \int_use:c { g__codehl_lang_dlimit_count_ #1 _int } _seq } }
                \seq_put_right:ce { g__codehl_lang_dlimit_count_ #1 _ \int_use:c { g__codehl_lang_dlimit_count_ #1 _int } _seq }
                  {
                    { \exp_not:V \l__codehl_tmpa_tl }
                    { \exp_not:V \l__codehl_tmpb_tl }
                    { \exp_not:V \l__codehl_tmpc_tl }
                    { \exp_not:V \l__codehl_tmpd_tl }
                    { \exp_not:n {#4} }
                  }
              }            
          }         
      } 
  }

\regex_const:Nn \c__codehl_scan_token_regex {\c{__codehl_scan_token:}}

\cs_new:Npn \__codehl_scan_stop:w #1 \scan_stop:
  {
    \fi:
  }


\cs_new:Npn \__codehl_peek_build:Nnnnnnn #1#2#3#4#5#6#7
  {
%    \tl_show:n {<<peek-build>>{#1}{#2}{#3}{#4}{#5}{#6}{#7}}

    \int_incr:N \l__codehl_dlimit_cnt_int
    \tl_if_empty:NTF #1
      {
        \tl_set:Nn \l__codehl_peek_build_tmp_tl 
          { 
            \cs_set_eq:NN \__codehl_tok_proc:N \__codehl_tok_GEN_other:N
            \tl_put_right:Nn \l__codehl_build_line_tl {#3}
            \__codehl_tok_proc:N
          }
      }
      {
        \tl_set_eq:NN \l__codehl_peek_build_tmp_tl #1
      }
      
      \tl_set:cn { l__codehl_lang_ #2 _dlimit_fmt_ \int_use:N \l__codehl_dlimit_cnt_int _tl }  
        {#7}

      \cs_set:cpe  { __codehl_lang_ #2 _ \int_use:N \l__codehl_dlimit_cnt_int _peek_end:N }
        {
          \exp_not:N \peek_regex_remove_once:nTF { \exp_not:n {#6} }
            {
              \exp_not:N \tl_put_right:Nn 
                 \exp_not:N \l__codehl_build_dlimit_tl 
                  { \exp_not:n {#5#6} }
              \exp_not:N \__codehl_fmt_comment:Non 
                \exp_not:c { l__codehl_lang_ #2 _dlimit_fmt_ \int_use:N \l__codehl_dlimit_cnt_int _tl } 
                \exp_not:N \l__codehl_build_dlimit_tl 
                {}
              \exp_not:N \tl_clear:N 
                \exp_not:N \l__codehl_build_dlimit_tl 
              \exp_not:N \cs_set_eq:NN 
                 \exp_not:N \__codehl_tok_proc:N 
                 \exp_not:N \__codehl_tok_GEN_other:N
              \exp_not:N \cs_set_eq:NN 
                \exp_not:N \__codehl_tok_start:N 
                \exp_not:N \__codehl_tok_GEN_other:N
              \exp_not:N \__codehl_tok_proc:N
            }
            {
              \exp_not:N \tl_put_right:No
                \exp_not:N \l__codehl_build_dlimit_tl 
                \exp_not:N \l__codehl_curr_token_tl
              \exp_not:N \__codehl_tok_proc:N
            }
        }
      
    \cs_set:cpe { __codehl_lang_ #2 _ \int_use:N \l__codehl_dlimit_cnt_int _scan_dlimit_end:N }
      {
        \exp_not:N \if_charcode:w 
          \exp_not:N \exp_not:o  \exp_not:N \l__codehl_curr_token_tl
          \exp_not:N \exp_not:N \exp_not:n {#5}
          \exp_not:N \cs_set_eq:NN
            \exp_not:N \__codehl_tok_proc:N 
            \exp_not:c { __codehl_lang_ #2 _ \int_use:N \l__codehl_dlimit_cnt_int _peek_end:N }   
          \exp_not:N \__codehl_scan_stop:w
        \exp_not:N \fi:
      }
     
      
    \tl_set:Ne #1
      {
        \exp_not:N \peek_regex_remove_once:nTF { \exp_not:n {#4} }
          {
            \exp_not:N \tl_set:Nn 
              \exp_not:N \l__codehl_build_dlimit_tl 
              { \exp_not:n {#3#4} }
            \exp_not:N \tl_set_eq:NN
              \exp_not:N \l__codehl_GEN_dlimit_fmt_tl
              \exp_not:c { l__codehl_lang_ #2 _dlimit_fmt_ \int_use:N \l__codehl_dlimit_cnt_int _tl }
            
             %%%\exp_not:o #2 %%% here!
             \exp_not:N \cs_set_eq:NN 
                \exp_not:N \__codehl_tok_scan_dlimit_end:N
                \exp_not:c { __codehl_lang_ #2 _ \int_use:N \l__codehl_dlimit_cnt_int _scan_dlimit_end:N }
%\exp_not:N \cs_show:N \exp_not:N \__codehl_tok_scan_dlimit_end:N
            \exp_not:N \cs_set_eq:NN 
              \exp_not:N \__codehl_tok_proc:N 
              \exp_not:N \__codehl_tok_GEN_dlimit:N
            \exp_not:N \__codehl_tok_proc:N
          }
          {
            \exp_not:o \l__codehl_peek_build_tmp_tl
          }
      }
  }

\int_new:N \l__codehl_dlimit_cnt_int
\cs_new_protected:Npn \__codehl_build_dlimit:n #1
  {
    \tl_clear:N \l__codehl_tmpa_tl
    \int_zero:N \l__codehl_dlimit_cnt_int
    \prop_map_inline:cn { g__codehl_lang_dlimit_ #1 _A_prop }
      {
        \tl_clear:N \l__codehl_tmpb_tl
        \seq_map_inline:Nn ##2
          {
            \__codehl_peek_build:Nnnnnnn \l__codehl_tmpb_tl {#1} ####1
          }
        \tl_put_right:Ne \l__codehl_tmpa_tl
          {
            \exp_not:N \if_charcode:w 
              \exp_not:N \exp_not:o \exp_not:N \l__codehl_curr_token_tl
              \exp_not:N \exp_not:N \exp_not:n {##1}
              \exp_not:N \cs_set:Npn \exp_not:N \__codehl_tok_proc:N 
                {
                  \exp_not:o \l__codehl_tmpb_tl
                }
              \exp_not:N \__codehl_scan_stop:w
            \exp_not:N \fi:
          }
      }
      \cs_set:cpe { __codehl_lang_ #1 _scan_dlimit:N }
        {
          \exp_not:o \l__codehl_tmpa_tl
        }
      \cs_show:c { __codehl_lang_ #1 _scan_dlimit:N }
  }


\cs_new:Npn \codehl_GEN:n #1
  {
    \cs_if_exist:NTF \g__codelist_verb_body_tl
      {
        \cs_set_eq:NN \__codehl_line_next:w \__codehl_line_proc:w
        \cs_set_eq:NN \__codehl_tok_start:N  \__codehl_tok_GEN_other:N %% it will (shall) handle just one token a time    
        %%% customization comes here !!!!
        \cs_set_eq:Nc \__codehl_tok_scan_dlimit:N { __codehl_lang_ #1 _scan_dlimit:N }
        \cs_set_eq:Nc \__codehl_tok_scan_dlimit_end:N { __codehl_lang_ #1 _scan_dlimit_end:N }
        
        %\tl_set:Ne \g__codehl_lang_tests_init_tl { \exp_not:c {g__codehl_lang_tests_init_#1_tl} }
        %\tl_set:Ne \g__codehl_lang_tests_tl { \exp_not:c {g__codehl_lang_tests_#1_tl} }
        
        
        
        \exp_last_unbraced:No \__codehl_line_proc:w \g__codelist_verb_body_tl \q_nil ^^J
      }
      {
        -nothing~here~\par
      }
  }



\cs_new:Npn \__codehl_tok_GEN_other:N #1 %% one, and only one... but can be any one
  {
    \if_meaning:w \q_nil #1
      \cs_set_eq:NN \__codehl_tok_proc:N \prg_do_nothing:
    \else:
      \if_catcode:w \exp_not:N #1 \c_catcode_letter_token
        \tl_put_right:Nn \l__codehl_build_keywd_tl #1
        \cs_set_eq:NN \__codehl_tok_proc:N \__codehl_tok_GEN_keywd:N
      \else:
        \tl_set:Nn \l__codehl_curr_token_tl {#1}
        \__codehl_tok_scan_dlimit:N
        \tl_put_right:Nn \l__codehl_build_line_tl {#1}
        \scan_stop:
      \fi:
    \fi:
    \__codehl_tok_proc:N
  }



\cs_new:Npn \__codehl_tok_GEN_keywd:N  #1 %% one, and only one... but can be any one
  {
    \if_meaning:w \q_nil #1
      \__codehl_fmt_keywd:co {g__codehl_def_keywd_ \g__codehl_activ_set_tl  _ \l__codehl_build_keywd_tl _tl} \l__codehl_build_keywd_tl
      \tl_clear:N \l__codehl_build_keywd_tl
      \cs_set_eq:NN \__codehl_tok_proc:N \prg_do_nothing:
    \else:
      \if_catcode:w \exp_not:N #1 \c_catcode_letter_token
        \tl_put_right:Nn \l__codehl_build_keywd_tl #1
      \else:
        \__codehl_fmt_keywd:co {g__codehl_def_keywd_ \g__codehl_activ_set_tl  _ \l__codehl_build_keywd_tl _tl} \l__codehl_build_keywd_tl
        \tl_clear:N \l__codehl_build_keywd_tl
        \cs_set_eq:NN \__codehl_tok_proc:N \__codehl_tok_GEN_other:N
        
        \tl_set:Nn \l__codehl_curr_token_tl {#1}
        \__codehl_tok_scan_dlimit:N
        \tl_put_right:Nn \l__codehl_build_line_tl {#1}
        \scan_stop:
      \fi:
    \fi:
    \__codehl_tok_proc:N
   }   


\cs_new:Npn \__codehl_tok_GEN_dlimit:N  #1 %% one, and only one... but can be any one
  {
    \if_meaning:w \q_nil #1
      \__codehl_fmt_comment:Non \l__codehl_GEN_dlimit_fmt_tl \l__codehl_build_dlimit_tl {}
      \tl_clear:N \l__codehl_build_dlimit_tl
      \cs_set_eq:NN \__codehl_tok_proc:N \prg_do_nothing:
      \cs_set_eq:NN \__codehl_tok_start:N \__codehl_tok_GEN_dlimit:N
    \else:
        \tl_set:Nn \l__codehl_curr_token_tl {#1}
        \__codehl_tok_scan_dlimit_end:N
        \tl_put_right:Nn \l__codehl_build_dlimit_tl {#1}
        \scan_stop:
    \fi:
    \__codehl_tok_proc:N
   }   
